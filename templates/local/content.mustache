{{#showcourseEdukav}}
    {{> format_edukav/local/course_header}}
{{/showcourseEdukav}}
<div id="course-format-{{uniqid}}" {{#subsectionsascards}}class="subsectionsascards"{{/subsectionsascards}}>
    <h2 class="accesshide">{{{title}}}</h2>
    {{{completionhelp}}}
    <ul class="card-deck dashboard-card-deck {{format}}"
         data-for="course_sectionlist">
        {{#sections}}
            {{$ format_edukav/local/content/section }}
                {{> format_edukav/local/content/section}}
            {{/format_edukav/local/content/section}}
        {{/sections}}
    </ul>
    <ul class="{{format}}">
        {{#initialsection}}
            {{$ format_edukav/local/content/section }}
                {{> format_edukav/local/content/section}}
            {{/format_edukav/local/content/section}}
        {{/initialsection}}
    </ul>
    {{#hasnavigation}}
    <div class="single-section">
        <ul class="edukav-single-section-list">
       {{#singlesection}}
        <div class="edukav-single-section-header">
            {{#sectionnavigation}}
                <div class="edukav-single-section-header-nav">
                    {{$ format_edukav/local/content/sectionnavigation }}
                        {{> format_edukav/local/content/sectionnavigation }}
                    {{/ format_edukav/local/content/sectionnavigation }}
                </div>
            {{/sectionnavigation}}
            <div class="edukav-single-section-header-meta">
                <div class="edukav-single-section-title">
                    {{{sectionheader.title}}}
                </div>
                <div class="edukav-single-section-progress-panel">
                    <span class="edukav-single-section-progress-label">{{#str}}ProgressModule,format_edukav{{/str}}</span>
                    {{#sectionprogress}}
                        <div class="edukav-single-section-progress-bar">
                            {{> block_myoverview/progress-bar }}
                        </div>
                    {{/sectionprogress}}
                    <span class="edukav-single-section-progress-value">{{sectionprogresspercentage}}%</span>
                </div>
            </div>
        </div>
        <div class="edukav-splitview" data-region="edukav-splitview">                    
            <div class="edukav-sidebar-shell">
                <div class="edukav-sidebar-header">
                    <span class="edukav-sidebar-header-title">Contenido del módulo</span>
                </div>
                <aside class="edukav-sidebar">
                 {{$ format_edukav/local/content/section }}
                    {{> format_edukav/local/content/section }}
                {{/ format_edukav/local/content/section }}
                </aside>
            </div>
            <main class="edukav-main">
                <div class="edukav-content-panel" data-region="splitview-content">
                    <div class="edukav-content-panel-header">
                        {{>format_edukav/local/button_splitview}}
                        <p class="edukav-content-panel-status" data-region="splitview-status">
                            Selecciona una actividad para verla aqui.
                        </p>
                    </div>
                    <iframe
                        class="edukav-activity-frame"
                        src=""
                        title="Vista previa de actividad"
                        data-region="splitview-frame"
                        frameborder="0"
                        loading="lazy">
                    </iframe>
                </div>
            </main>

        </div>

        {{/singlesection}}
        </ul>
        {{#sectionselector}}
            {{$ format_edukav/local/content/sectionselector }}
                {{> format_edukav/local/content/sectionselector }}
            {{/ format_edukav/local/content/sectionselector }}
        {{/sectionselector}}
    </div>
    {{/hasnavigation}}
    {{#numsections}}
        {{$ core_courseformat/local/content/addsection}}
            {{> core_courseformat/local/content/addsection}}
        {{/ core_courseformat/local/content/addsection}}
    {{/numsections}}
    {{#bulkedittools}}
        {{$ core_courseformat/local/content/bulkedittools}}
            {{> core_courseformat/local/content/bulkedittools}}
        {{/ core_courseformat/local/content/bulkedittools}}
    {{/bulkedittools}}
</div>
{{#js}}
require([
    'core_courseformat/local/content',
    'format_edukav/cards',
    'format_edukav/main',
    'format_edukav/aside_toggle'
], function(component, cards,main,aside_toggle) {

    component.init('{{#moodle500orlater}}#{{/moodle500orlater}}course-format-{{uniqid}}', {}, {{sectionreturn}});
    cards.init('course-format-{{uniqid}}');
    main.init();
    aside_toggle.init();
});
{{/js}}
